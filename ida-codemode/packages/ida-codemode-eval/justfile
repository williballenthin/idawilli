set quiet

format:
    uvx --quiet ruff format --quiet ida_codemode_eval/ tests/

ruff:
    uvx --quiet ruff check --quiet --fix ida_codemode_eval/ tests/
    uvx --quiet ruff check --quiet --select I --fix ida_codemode_eval/ tests/

mypy:
    uv run --quiet --directory ../.. mypy --no-error-summary packages/ida-codemode-eval/ida_codemode_eval/

test:
    uv run --quiet --directory ../.. pytest -x -q --no-header packages/ida-codemode-eval/tests/

lint: format ruff mypy

all: lint test
