set quiet

format:
    uvx --quiet ruff format --quiet ida_codemode_api/ tests/

ruff:
    uvx --quiet ruff check --quiet --fix ida_codemode_api/ tests/
    uvx --quiet ruff check --quiet --select I --fix ida_codemode_api/ tests/

mypy:
    uv run --quiet --directory ../.. mypy --no-error-summary packages/ida-codemode-api/ida_codemode_api/

test:
    uv run --quiet --directory ../.. pytest -x -q --no-header packages/ida-codemode-api/tests/

rebuild-api-reference:
    PYTHONPATH=. python -c 'from pathlib import Path; from ida_codemode_api.api import api_reference; text = api_reference() + "\n"; Path("ida_codemode_api/prompts/api_reference.md").write_text(text + "\n<!--- (autogenerated file: do not edit) -->\n", encoding="utf-8");'

docs: rebuild-api-reference

lint: format ruff mypy

all: docs lint test
